---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="bg-surface-container-lowest border-t border-outline-variant/50 w-full mt-24">
  <div
    class="grid grid-cols-1 md:grid-cols-3 gap-gutter px-margin-desktop py-section-padding max-w-container-max mx-auto"
  >
    <div class="md:col-span-1">
      <div class="flex items-center gap-2 mb-6">
        <img
          alt="Pulsi Logo"
          class="h-8 w-8 object-contain"
          src={`${base}images/hero.png`}
        />
        <span class="text-headline-lg font-headline-lg font-extrabold text-primary">Pulsi</span>
      </div>
      <p class="text-body-md font-body-md text-on-surface-variant mb-6">
        Cuidamos a las personas. Impulsamos resultados.
      </p>
    </div>

    <div>
      <h4 class="text-label-sm font-label-sm text-on-surface-variant uppercase tracking-wider mb-6">
        Navegación
      </h4>
      <ul class="space-y-4">
        <li>
          <a
            class="text-body-md font-body-md text-on-surface-variant hover:text-primary transition-colors"
            href="#features">El Problema</a
          >
        </li>
        <li>
          <a
            class="text-body-md font-body-md text-on-surface-variant hover:text-primary transition-colors"
            href="#solutions">Soluciones</a
          >
        </li>
        <li>
          <a
            class="text-body-md font-body-md text-on-surface-variant hover:text-primary transition-colors"
            href="#faq">Preguntas frecuentes</a
          >
        </li>
      </ul>
    </div>

    <div>
      <h4 class="text-label-sm font-label-sm text-on-surface-variant uppercase tracking-wider mb-6">
        Contacto
      </h4>
      <ul class="space-y-4">
        <li>
          <a
            class="text-body-md font-body-md text-on-surface-variant hover:text-primary transition-colors"
            href="mailto:contacto@pulsi.cl">contacto@pulsi.cl</a
          >
        </li>
      </ul>
    </div>
  </div>

  <div
    class="max-w-container-max mx-auto px-margin-desktop py-8 border-t border-outline-variant/30 flex justify-center items-center text-label-sm font-label-sm text-on-surface-variant"
  >
    <span>© {year} Pulsi. Todos los derechos reservados.</span>
  </div>
</footer>
