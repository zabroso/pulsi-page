---
const base = import.meta.env.BASE_URL;
---

<footer class="bg-surface-container-lowest border-t border-outline-variant/50 w-full mt-24">
  <div
    class="grid grid-cols-1 md:grid-cols-4 gap-gutter px-margin-desktop py-section-padding max-w-container-max mx-auto"
  >
    <div class="md:col-span-1">
      <div class="flex items-center gap-2 mb-6">
        <img
          alt="Pulsi Logo"
          class="h-8 w-8 object-contain"
          src={`${base}images/hero.png`}
        />
        <span class="text-headline-lg font-headline-lg font-extrabold text-primary">Pulsi</span>
      </div>
      <p class="text-body-md font-body-md text-on-surface-variant mb-6">
        Cuidamos a las personas. Impulsamos resultados.
      </p>
    </div>

    <div>
      <h4 class="text-label-sm font-label-sm text-on-surface-variant uppercase tracking-wider mb-6">
        Product
      </h4>
      <ul class="space-y-4">
        <li>
          <a
            class="text-body-md font-body-md text-on-surface-variant hover:text-primary transition-colors"
            href="#">Platform</a
          >
        </li>
        <li>
          <a
            class="text-body-md font-body-md text-on-surface-variant hover:text-primary transition-colors"
            href="#">Integrations</a
          >
        </li>
        <li>
          <a
            class="text-body-md font-body-md text-on-surface-variant hover:text-primary transition-colors"
            href="#">Pricing</a
          >
        </li>
      </ul>
    </div>

    <div>
      <h4 class="text-label-sm font-label-sm text-on-surface-variant uppercase tracking-wider mb-6">
        Company
      </h4>
      <ul class="space-y-4">
        <li>
          <a
            class="text-body-md font-body-md text-on-surface-variant hover:text-primary transition-colors"
            href="#">About Us</a
          >
        </li>
        <li>
          <a
            class="text-body-md font-body-md text-on-surface-variant hover:text-primary transition-colors"
            href="#">Careers</a
          >
        </li>
        <li>
          <a
            class="text-body-md font-body-md text-on-surface-variant hover:text-primary transition-colors"
            href="#">Blog</a
          >
        </li>
      </ul>
    </div>

    <div>
      <h4 class="text-label-sm font-label-sm text-on-surface-variant uppercase tracking-wider mb-6">
        Support
      </h4>
      <ul class="space-y-4">
        <li>
          <a
            class="text-body-md font-body-md text-on-surface-variant hover:text-primary transition-colors"
            href="#faq">Help Center</a
          >
        </li>
        <li>
          <a
            class="text-body-md font-body-md text-on-surface-variant hover:text-primary transition-colors"
            href="#">Privacy Policy</a
          >
        </li>
        <li>
          <a
            class="text-body-md font-body-md text-on-surface-variant hover:text-primary transition-colors"
            href="#">Terms of Service</a
          >
        </li>
      </ul>
    </div>
  </div>

  <div
    class="max-w-container-max mx-auto px-margin-desktop py-8 border-t border-outline-variant/30 flex justify-between items-center text-label-sm font-label-sm text-on-surface-variant"
  >
    <span>© 2024 Pulsi. Todos los derechos reservados.</span>
    <div class="flex gap-6">
      <a class="hover:text-primary transition-colors" href="#">Twitter</a>
      <a class="hover:text-primary transition-colors" href="#">LinkedIn</a>
    </div>
  </div>
</footer>
