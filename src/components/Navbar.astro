---
const base = import.meta.env.BASE_URL;
---

<nav
  class="fixed top-0 w-full z-50 glass-nav border-b border-outline-variant/30 shadow-sm transition-all duration-300 h-20"
>
  <div
    class="flex justify-between items-center h-full px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto"
  >
    <a class="flex items-center gap-2 group" href="#">
      <img
        alt="Pulsi Logo"
        class="h-10 w-10 object-contain transition-transform group-hover:scale-110"
        src={`${base}images/hero.png`}
      />
      <span class="text-headline-xl font-headline-xl font-bold text-primary">Pulsi</span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      <a
        class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors"
        href="#features">Platform</a
      >
      <a
        class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors"
        href="#solutions">Features</a
      >
      <a
        class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors"
        href="#case-studies">Case Studies</a
      >
      <a
        class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors"
        href="#faq">FAQ</a
      >
    </div>

    <div class="flex items-center gap-4">
      <button
        class="hidden sm:block font-label-md text-label-md text-primary font-bold px-4 py-2 hover:bg-primary-container/10 rounded-lg transition-all"
      >
        Login
      </button>
      <button
        class="primary-gradient text-on-primary font-label-md text-label-md font-bold px-6 py-3 rounded-full shadow-lg shadow-primary/20 scale-100 hover:scale-105 active:scale-95 transition-transform"
      >
        Request Demo
      </button>
    </div>
  </div>
</nav>
